{
  "name": "safari-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Local Playwright helper for turning pasted safari itineraries into Safari Portal drafts.",
  "main": "desktop/main.js",
  "scripts": {
    "app": "node src/server.js",
    "build": "node src/index.js build",
    "desktop": "node desktop/launch.js",
    "login": "node src/index.js login",
    "parse": "node src/index.js parse",
    "test": "node --test",
    "dist": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac"
  },
  "dependencies": {
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.safaribot.app",
    "productName": "Safari Bot",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "src/**/*",
      "web/**/*",
      "config/**/*",
      "data/**/*",
      "examples/**/*",
      "package.json",
      "!config/portal.json",
      "!config/portal.debug.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "identity": null
    }
  }
}
